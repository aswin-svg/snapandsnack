<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gallery — Snap & Snack</title>
  <meta name="description" content="Photo gallery — moments captured from travels around the world by Aswin.">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Gallery — Snap & Snack">
  <meta property="og:description" content="Photo gallery — moments captured from travels around the world.">
  <meta property="og:url" content="https://snapandsnack.up.railway.app/gallery">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="stylesheet" href="/css/gallery.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
</head>
<body>

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">Snap &amp; <span>Snack</span></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/gallery" class="active">Gallery</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <div class="toggle-track" id="dark-toggle" onclick="toggleDark()" title="Toggle dark mode">
  <div class="toggle-thumb" id="toggle-thumb">☀️</div>
</div>
</div>
        
      </div>
      <button class="nav-hamburger" onclick="toggleMenu()">☰</button>
    </div>
    <div class="nav-mobile" id="nav-mobile">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <div class="toggle-track" id="dark-toggle" onclick="toggleDark()" title="Toggle dark mode">
  <div class="toggle-thumb" id="toggle-thumb">☀️</div>
</div>
</div>
    </div>
  </nav>

  <div class="container">
    <div class="gallery-header">
      <h1>Photo Gallery</h1>
      <p>Moments captured from the road 📷 — <span id="photo-count"><%= photos.length %></span> photos</p>
    </div>

    <!-- Filter bar -->
    <% if (photos.length > 0) { %>
    <div class="gallery-filter-bar">
      <button class="gallery-filter-btn active" onclick="filterGallery('all', this)">All</button>
      <%
        const allCaptions = photos.map(p => p.caption).filter(Boolean);
        const keywords = [...new Set(allCaptions.flatMap(c => c.split(/[,\s]+/).filter(w => w.length > 3)))].slice(0, 8);
        keywords.forEach(kw => {
      %>
        <button class="gallery-filter-btn" onclick="filterGallery('<%= kw.toLowerCase() %>', this)"><%= kw %></button>
      <% }) %>
      <div class="gallery-search-box">
        <input type="text" id="gallery-search" placeholder="Search photos..." oninput="searchGallery(this.value)">
      </div>
    </div>
    <% } %>
  </div>

  <% if (photos.length === 0) { %>
    <div class="container">
      <div class="empty-state">
        <div class="empty-icon">📷</div>
        <p>No photos yet — upload your first shots in the admin panel!</p>
        <a href="/admin/gallery" class="btn btn-accent">Upload photos</a>
      </div>
    </div>
  <% } else { %>

  <!-- Photo Grid -->
  <div class="portfolio" id="photo-grid">
    <% photos.forEach((photo, i) => { %>
      <div class="project" 
           data-caption="<%= (photo.caption || '').toLowerCase() %>"
           data-src="<%= photo.src %>">
        <img class="project__image" src="<%= photo.src %>" alt="<%= photo.caption || 'Travel photo' %>" loading="lazy">
        <% if (photo.caption) { %>
          <p class="project__tag"><%= photo.caption.split(',')[0] %></p>
          <h3 class="project__title"><%= photo.caption %></h3>
        <% } else { %>
          <p class="project__tag">📷</p>
          <h3 class="project__title">Travel photo</h3>
        <% } %>
        <div class="grid__overlay">
          <button class="view-btn" onclick="openLightbox('<%= photo.src %>', '<%= (photo.caption || '').replace(/'/g, "\\'") %>')">View photo</button>
        </div>
      </div>
    <% }) %>
  </div>

  <div id="no-results" style="display:none" class="container">
    <div class="empty-state">
      <div class="empty-icon">🔍</div>
      <p>No photos found.</p>
      <button class="btn btn-outline" onclick="filterGallery('all', document.querySelector('.gallery-filter-btn'))">Show all</button>
    </div>
  </div>

  <% } %>

  <!-- Lightbox -->
  <div class="lightbox-overlay" id="lightbox" onclick="closeLightbox(event)">
    <div class="lightbox-inner">
      <button class="lightbox-close" onclick="closeLightbox()">✕</button>
      <img id="lightbox-img" src="" alt="">
      <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>
  </div>

  <!-- Back to top -->
  <button class="back-to-top" id="back-to-top" onclick="scrollToTop()" title="Back to top">↑</button>

  <!-- Dark mode toggle -->
  

  <footer class="footer">
    <div class="container">
      <div class="footer-bottom">© <%= new Date().getFullYear() %> Snap & Snack</div>
    </div>
  </footer>

  <script>
    function toggleMenu() { document.getElementById('nav-mobile').classList.toggle('open'); }

    // Lightbox
    function openLightbox(src, caption) {
      document.getElementById('lightbox-img').src = src;
      document.getElementById('lightbox-caption').textContent = caption;
      document.getElementById('lightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox(e) {
      if (!e || e.target === document.getElementById('lightbox') || e.target.classList.contains('lightbox-close')) {
        document.getElementById('lightbox').classList.remove('open');
        document.body.style.overflow = '';
      }
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

    // Filter
    function filterGallery(keyword, btn) {
      document.querySelectorAll('.gallery-filter-btn').forEach(b => b.classList.remove('active'));
      if (btn) btn.classList.add('active');
      document.getElementById('gallery-search').value = '';
      const items = document.querySelectorAll('.project');
      let visible = 0;
      items.forEach(item => {
        const show = keyword === 'all' || item.dataset.caption.includes(keyword.toLowerCase());
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
      document.getElementById('photo-count').textContent = visible;
    }

    // Search
    function searchGallery(val) {
      document.querySelectorAll('.gallery-filter-btn').forEach(b => b.classList.remove('active'));
      const items = document.querySelectorAll('.project');
      let visible = 0;
      items.forEach(item => {
        const show = !val || item.dataset.caption.includes(val.toLowerCase());
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.getElementById('no-results').style.display = visible === 0 && val ? 'block' : 'none';
      document.getElementById('photo-count').textContent = visible;
    }

    // Back to top
    window.addEventListener('scroll', () => {
      document.getElementById('back-to-top').classList.toggle('visible', window.scrollY > 300);
    });
    function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }

    // Dark mode
    function toggleDark() {
  const isDark = document.documentElement.classList.toggle('dark');
  localStorage.setItem('darkMode', isDark);
  document.getElementById('dark-toggle').classList.toggle('on', isDark);
  document.getElementById('toggle-thumb').textContent = isDark ? '🌙' : '☀️';
}
if (localStorage.getItem('darkMode') === 'true') {
  document.documentElement.classList.add('dark');
  document.getElementById('dark-toggle').classList.add('on');
  document.getElementById('toggle-thumb').textContent = '🌙';
}
  </script>

</body>
</html>
