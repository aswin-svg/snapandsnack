<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> — Snap & Snack</title>
  <meta name="description" content="<%= post.content.substring(0,150).replace(/\n/g,' ') %>">
  <meta property="og:type" content="article">
  <meta property="og:title" content="<%= post.title %>">
  <meta property="og:description" content="<%= post.content.substring(0,150).replace(/\n/g,' ') %>">
  <meta property="og:image" content="<%= post.image ? 'https:// snapandsnack-production.up.railway.app' + post.image : 'https:// snapandsnack-production.up.railway.app/favicon.svg' %>">
  <meta property="og:url" content="https:// snapandsnack-production.up.railway.app/post/<%= post.slug %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= post.title %>">
  <meta name="twitter:description" content="<%= post.content.substring(0,150).replace(/\n/g,' ') %>">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <!-- Google Analytics -->

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-N9JTYL4795"></script>

  <script>

    window.dataLayer = window.dataLayer || [];

    function gtag(){dataLayer.push(arguments);}

    gtag('js', new Date());

    gtag('config', 'G-N9JTYL4795');

  </script>


</head>
<body>

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">Snap &amp; <span>Snack</span></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/gallery">Gallery</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <div class="toggle-track" id="dark-toggle" onclick="toggleDark()" title="Toggle dark mode">
  <div class="toggle-thumb" id="toggle-thumb">☀️</div>
</div>
</div>
      </div>
      <button class="nav-hamburger" onclick="toggleMenu()">☰</button>
    </div>
    <div class="nav-mobile" id="nav-mobile">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <div class="toggle-track" id="dark-toggle" onclick="toggleDark()" title="Toggle dark mode">
  <div class="toggle-thumb" id="toggle-thumb">☀️</div>
</div>
    </div>
  </nav>

  <div class="container-sm">
    <a href="/blog" class="back-link">← Back to blog</a>

    <div class="post-header">
      <div class="post-meta-row">
        <span class="cat-badge cat-<%= post.category.toLowerCase() %>"><%= post.category %></span>
        <span class="post-date"><%= post.date %></span>
        <span class="post-read-time">⏱️ <%= readTime %> min read</span>
        <span class="post-views">👁️ <%= post.views || 1 %> views</span>
      </div>
      <h1><%= post.title %></h1>
      <% if (post.tags.length > 0) { %>
        <div class="post-tags" style="justify-content:center">
          <% post.tags.forEach(t => { %><span class="tag">#<%= t %></span><% }) %>
        </div>
      <% } %>
    </div>

    <% if (post.image) { %>
      <img src="<%= post.image %>" alt="<%= post.title %>" class="post-hero-img">
    <% } %>

    <div class="post-body"><%- renderContent(post.content) %></div>

    <div class="share-row">
  <span class="share-label">Share this post</span>
  <div class="share-btns-new">
    <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(post.title) %>&url=<%= encodeURIComponent('https:// snapandsnack-production.up.railway.app/post/' + post.slug) %>" target="_blank" class="share-circle share-twitter" title="Share on Twitter">𝕏</a>
    <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('https:// snapandsnack-production.up.railway.app/post/' + post.slug) %>" target="_blank" class="share-circle share-facebook" title="Share on Facebook">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
    </a>
    <a href="https://wa.me/?text=<%= encodeURIComponent(post.title + ' — ' + 'https:// snapandsnack-production.up.railway.app/post/' + post.slug) %>" target="_blank" class="share-circle share-whatsapp" title="Share on WhatsApp">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
    </a>
    <button class="share-circle share-copy" title="Copy link" onclick="navigator.clipboard.writeText(window.location.href);this.classList.add('copied');this.innerHTML='✓';setTimeout(()=>{this.classList.remove('copied');this.innerHTML='🔗'},1500)">🔗</button>
  </div>
</div>

    <!-- ░░ COMMENTS SECTION ░░ -->
    <div class="comments-section">
      <h2 class="comments-title">
        💬 Comments
        <span class="comments-count"><%= post.comments ? post.comments.length : 0 %></span>
      </h2>

      <!-- Comment form -->
      <form class="comment-form" method="POST" action="/post/<%= post.slug %>/comment">
        <div class="comment-form-row">
          <div class="form-group">
            <label>Your name *</label>
            <input type="text" name="name" placeholder="e.g. Sarah" required>
          </div>
          <div class="form-group">
            <label>Email <span style="color:var(--muted);font-weight:300">(not shown publicly)</span></label>
            <input type="email" name="email" placeholder="your@email.com">
          </div>
        </div>
        <div class="form-group">
          <label>Comment *</label>
          <textarea name="comment" rows="4" placeholder="Share your thoughts..." required></textarea>
        </div>
        <button type="submit" class="btn btn-accent">Post comment →</button>
      </form>

      <!-- Comments list -->
      <% if (post.comments && post.comments.length > 0) { %>
        <div class="comments-list">
          <% post.comments.slice().reverse().forEach(c => { %>
            <div class="comment-card">
              <div class="comment-header">
                <div class="comment-avatar"><%= c.name.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="comment-name"><%= c.name %></div>
                  <div class="comment-date"><%= c.date %></div>
                </div>
              </div>
              <p class="comment-body"><%= c.comment %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="no-comments">No comments yet — be the first! 👆</div>
      <% } %>
    </div>

    <!-- Related posts -->
    <% if (related.length > 0) { %>
      <div class="related-section">
        <h2 class="section-title">More in <%= post.category %></h2>
        <div class="posts-grid">
          <% related.forEach(r => { %>
            <article class="post-card">
              <% if (r.image) { %>
                <a href="/post/<%= r.slug %>"><img src="<%= r.image %>" alt="<%= r.title %>" class="post-card-img"></a>
              <% } else { %>
                <a href="/post/<%= r.slug %>"><div class="post-card-img-placeholder">📷</div></a>
              <% } %>
              <div class="post-card-body">
                <span class="cat-badge cat-<%= r.category.toLowerCase() %>"><%= r.category %></span>
                <h3><a href="/post/<%= r.slug %>"><%= r.title %></a></h3>
                <div class="post-card-footer">
                  <span class="post-date"><%= r.date %></span>
                  <a href="/post/<%= r.slug %>" class="post-link">Read →</a>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Back to top -->
  <button class="back-to-top" id="back-to-top" onclick="scrollToTop()" title="Back to top">↑</button>
  <!-- Dark mode toggle -->
  

  <footer class="footer">
    <div class="container">
      <div class="footer-bottom">© <%= new Date().getFullYear() %> Snap & Snack</div>
    </div>
  </footer>

  <script>
    function toggleMenu() { document.getElementById('nav-mobile').classList.toggle('open'); }
    window.addEventListener('scroll', () => {
      document.getElementById('back-to-top').classList.toggle('visible', window.scrollY > 300);
    });
    function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
    function toggleDark() {
  const isDark = document.documentElement.classList.toggle('dark');
  localStorage.setItem('darkMode', isDark);
  document.getElementById('dark-toggle').classList.toggle('on', isDark);
  document.getElementById('toggle-thumb').textContent = isDark ? '🌙' : '☀️';
}
if (localStorage.getItem('darkMode') === 'true') {
  document.documentElement.classList.add('dark');
  document.getElementById('dark-toggle').classList.add('on');
  document.getElementById('toggle-thumb').textContent = '🌙';
}
  </script>

</body>
</html>
