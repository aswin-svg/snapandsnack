<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Password — Snap & Snack Admin</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">

  <nav class="admin-nav">
    <div class="admin-nav-inner">
      <div style="display:flex;align-items:center;gap:0.5rem">
        <a href="/" class="admin-logo">Snap &amp; <span>Snack</span></a>
        <span class="admin-badge">Admin</span>
      </div>
      <div class="admin-nav-links">
        <a href="/admin" class="btn btn-outline btn-sm">← Dashboard</a>
        <a href="/admin/logout" class="btn btn-outline btn-sm">Log out</a>
      </div>
    </div>
  </nav>

  <div class="admin-main">
    <h1 style="font-size:1.5rem;font-weight:600;margin-bottom:1.5rem">🔑 Change Password</h1>

    <% if (success) { %>
      <div style="background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;padding:1rem;border-radius:8px;margin-bottom:1.5rem;font-size:0.95rem">
        ✅ Password changed successfully!
      </div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/password" class="form-card" style="max-width:480px">
      <div class="form-group">
        <label>Current password</label>
        <input type="password" name="current" placeholder="Your current password" required>
      </div>
      <div class="form-group">
        <label>New password</label>
        <input type="password" name="newpass" placeholder="At least 6 characters" required>
      </div>
      <div class="form-group">
        <label>Confirm new password</label>
        <input type="password" name="confirm" placeholder="Type new password again" required>
      </div>
      <div class="form-actions">
        <a href="/admin" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-accent">Save new password</button>
      </div>
    </form>
  </div>

</body>
</html>
