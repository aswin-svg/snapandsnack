<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
<meta name="google-site-verification" content="H368pHEGtC5NQuly-6ctSLDHJYas2r13e-9hMkbzbdo">
  <title>Admin Login — Snap & Snack</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <h1>Snap &amp; <span style="color:var(--accent)">Snack</span></h1>
      <p>Sign in to manage your blog</p>
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label>Username</label>
          <input type="text" name="username" placeholder="admin" required autofocus>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-accent btn-full">Sign in →</button>
      </form>
      <p class="login-hint">Default: admin / admin123</p>
    </div>
  </div>
</body>
</html>
